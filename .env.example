# ---- Database ----
# Postgres connection string. Use a managed DB in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chores?schema=public"

# ---- Session signing ----
# Run:  openssl rand -base64 48   to generate a strong value.
# Must be at least 32 characters. Changing this will log everyone out.
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# ---- Bootstrap token ----
# Used only on /setup to create the very first parent account.
# Generate:  openssl rand -hex 24
# Rotate (or unset) after the first parent is created.
BOOTSTRAP_TOKEN="rotate-me-after-first-parent-setup"

# ---- App settings ----
APP_TIMEZONE="Europe/Moscow"
PARENT_SESSION_DAYS="7"
CHILD_SESSION_DAYS="30"

# ---- Deployment ----
# The base URL of the deployed app (used for absolute URLs where needed).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" in production; affects cookie Secure flag.
# NODE_ENV is already set by Next/Vercel — this is a hint only.
